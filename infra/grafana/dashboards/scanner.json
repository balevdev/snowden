    "from": "now-14d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Scanner Funnel",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT * FROM scanner_funnel_daily ORDER BY bucket DESC LIMIT 14",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Scan Duration",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT ts, duration_ms FROM scanner_metrics ORDER BY ts",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
