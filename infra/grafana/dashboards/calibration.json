{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Brier Score Over Time",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', ts) AS time, AVG(brier_score) AS brier_score FROM prediction_accuracy_hourly GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      }
    },
    {
      "title": "Prediction Count",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', ts) AS time, SUM(n_predictions) AS predictions FROM prediction_accuracy_hourly GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Average Confidence",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', ts) AS time, AVG(avg_confidence) AS avg_confidence FROM prediction_accuracy_hourly GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Average Edge",
      "type": "timeseries",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 hour', ts) AS time, AVG(avg_edge) AS avg_edge FROM prediction_accuracy_hourly GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "title": "Reliability Buckets",
      "type": "barchart",
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "rawSql": "SELECT width_bucket(p_est, 0, 1, 10) AS bucket, AVG(p_est) AS avg_predicted, AVG(outcome::int) AS avg_actual, COUNT(*) AS n FROM predictions WHERE resolved = true GROUP BY 1 ORDER BY 1",
          "format": "table"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["snowden", "calibration"],
  "templating": { "list": [] },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Snowden - Calibration",
  "uid": "snowden-calibration"
}
