{
  "uid": "snowden-overview",
  "title": "Snowden - Overview",
  "tags": ["snowden"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Equity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT ts, total_equity FROM portfolio_snapshots ORDER BY ts",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Daily P&L",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT time_bucket('1 day', ts) as time, SUM(daily_pnl) as pnl FROM portfolio_snapshots GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Brier Score",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT brier_score FROM prediction_accuracy_hourly ORDER BY bucket DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Current Heat",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT heat FROM portfolio_snapshots ORDER BY ts DESC LIMIT 1",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Trade Log",
      "type": "table",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 12 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT ts, market_id, direction, size, price, status, strategy FROM trades ORDER BY ts DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Strategy Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": { "type": "postgres", "uid": "TimescaleDB" },
      "targets": [
        {
          "rawSql": "SELECT strategy, COUNT(*) as count FROM trades GROUP BY strategy",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
